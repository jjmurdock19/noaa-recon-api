# See recon-met-update.service for install instructions — install both
# files together, then enable/start only the .timer (it pulls in the
# .service each time it fires).
#
# Fires 30 minutes after storm-archive-update.timer (03:15) so the two
# nightly crawls don't compete for network/CPU at the exact same instant.
[Unit]
Description=Nightly trigger for recon-met-update.service

[Timer]
OnCalendar=*-*-* 03:45:00
Persistent=true

[Install]
WantedBy=timers.target
